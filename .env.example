APP_ENV=development
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Primary database — PostgreSQL + pgvector (required for production & RAG)
DATABASE_URL=postgresql://medvision:medvision@localhost:5432/medvision

# Optional quick dev without Docker (no vector search):
# DATABASE_URL=sqlite+pysqlite:///./medvision_dev.db

REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7
ML_INFERENCE_BASE_URL=http://localhost:8001
STORAGE_PATH=./data/uploads
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Vector / RAG (pgvector in PostgreSQL)
EMBEDDING_DIMENSIONS=384
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
VECTOR_SEARCH_LIMIT=5

# Chest X-ray AI (TorchXRayVision)
IMAGING_MODEL_NAME=densenet121-res224-all
IMAGING_WEIGHTS_DIR=./models/imaging
IMAGING_DEVICE=cpu
IMAGING_DETECTION_THRESHOLD=0.5

# OpenAI — summaries (embeddings use local MiniLM by default)
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
